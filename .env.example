# Backend: "offline" (default, no keys) or "openai"
RAG_BACKEND=offline

# Required only when RAG_BACKEND=openai
RAG_OPENAI_API_KEY=
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHAT_MODEL=gpt-4o-mini

# Retrieval tuning
RAG_TOP_K=4
RAG_MAX_CONTEXT_TOKENS=1500
RAG_MIN_SCORE=0.05
RAG_EMBEDDING_DIM=256
